{
  "name": "tony-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node tools/run-nx.js serve shell",
    "dev:all": "node tools/dev-all.js",
    "dev:shell": "node tools/run-nx.js serve shell",
    "dev:auth": "node tools/run-nx.js serve mfeAuth",
    "dev:compliance": "node tools/run-nx.js serve mfeCompliance",
    "dev:onboarding": "node tools/run-nx.js serve mfeOnboarding",
    "dev:admin": "node tools/run-nx.js serve mfeAdmin",
    "dev:payments": "node tools/run-nx.js serve mfePayments",
    "dev:treasury": "node tools/run-nx.js serve mfeTreasury",
    "dev:analytics": "node tools/run-nx.js serve mfe-analytics",
    "dev:docs": "node tools/run-nx.js serve docs",
    "build": "npm run build:apps",
    "build:apps": "node tools/run-nx.js run-many --target=build --projects=shell,mfePayments,mfeTreasury,mfeAuth,mfeCompliance,mfeOnboarding,mfeAdmin,mfe-analytics,docs --parallel=5",
    "build:all": "npm run build:apps",
    "build:schematics": "tsc -p projects/core/schematics/tsconfig.schematics.json && copyfiles -u 3 projects/core/schematics/**/schema.json projects/core/schematics/collection.json dist/core/schematics",
    "ci:validate": "node tools/run-nx.js run-many --target=lint --projects=shell,mfePayments,mfeTreasury,mfeAuth,mfeCompliance,mfeOnboarding,mfeAdmin,mfe-analytics,docs --parallel=3 && node tools/run-nx.js run-many --target=test --projects=core,shell,mfePayments,mfeTreasury,mfeAuth,mfeCompliance,mfeOnboarding,mfeAdmin,mfe-analytics,docs --parallel=3 && node tools/run-nx.js run-many --target=build --projects=core,shell,mfePayments,mfeTreasury,mfeAuth,mfeCompliance,mfeOnboarding,mfeAdmin,mfe-analytics,docs --configuration=production --parallel=5",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "watch": "node tools/run-nx.js run-many --target=build --projects=shell,mfePayments,mfeTreasury,mfeAuth,mfeCompliance,mfeOnboarding,mfeAdmin,mfe-analytics,docs --configuration=development --parallel=5",
    "test": "node tools/run-nx.js run-many --target=test --projects=core,shell,mfePayments,mfeTreasury,mfeAuth,mfeCompliance,mfeOnboarding,mfeAdmin,mfe-analytics,docs --parallel=3 --watch=false",
    "test:watch": "node tools/run-nx.js run-many --target=test --projects=core,shell,mfePayments,mfeTreasury,mfeAuth,mfeCompliance,mfeOnboarding,mfeAdmin,mfe-analytics,docs --parallel=3",
    "docs:dev": "node tools/run-nx.js serve docs",
    "docs:build": "node tools/run-nx.js build docs --configuration production",
    "prepublish:core": "ng-packagr -p projects/core/ng-package.json && npm run build:schematics",
    "publish:core": "cd dist/core && npm publish --access public"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/aria": "21.2.7",
    "@angular/cdk": "21.2.7",
    "@angular/common": "21.2.9",
    "@angular/compiler": "21.2.9",
    "@angular/core": "21.2.9",
    "@angular/forms": "21.2.9",
    "@angular/platform-browser": "21.2.9",
    "@angular/router": "21.2.9",
    "@nx/angular": "22.6.5",
    "@tony-ui/core": "file:projects/core",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "prismjs": "^1.30.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.7",
    "@angular-devkit/core": "^21.0.5",
    "@angular-devkit/schematics": "^21.0.5",
    "@angular/build": "21.2.7",
    "@angular/cli": "21.2.7",
    "@angular/compiler-cli": "21.2.9",
    "@eslint/js": "^9.8.0",
    "@module-federation/enhanced": "^2.1.0",
    "@nx/eslint": "22.6.5",
    "@nx/eslint-plugin": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/module-federation": "22.6.5",
    "@nx/react": "^22.6.5",
    "@nx/web": "22.6.5",
    "@nx/webpack": "22.6.5",
    "@nx/workspace": "22.6.5",
    "@schematics/angular": "^21.0.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/utils": "^8.40.0",
    "angular-eslint": "^21.2.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "nx": "22.6.5",
    "postcss": "^8.5.8",
    "prettier": "~3.6.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vitest": "^4.0.8",
    "webpack-cli": "^7.0.2"
  }
}
