{
  "name": "mfeCompliance",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/mfe-compliance/src",
  "tags": ["scope:domain-compliance", "type:app"],
  "targets": {
    "build": {
      "executor": "@nx/angular:webpack-browser",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/mfe-compliance",
        "index": "apps/mfe-compliance/src/index.html",
        "main": "apps/mfe-compliance/src/main.ts",
        "tsConfig": "apps/mfe-compliance/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/mfe-compliance/public"
          }
        ],
        "styles": [
          "apps/mfe-compliance/src/styles.css"
        ],
        "customWebpackConfig": {
          "path": "apps/mfe-compliance/webpack.config.ts"
        }
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "customWebpackConfig": {
            "path": "apps/mfe-compliance/webpack.prod.config.ts"
          }
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "test-build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/test-mfe-compliance",
        "index": "apps/mfe-compliance/src/index.html",
        "browser": "apps/mfe-compliance/src/main.ts",
        "tsConfig": "apps/mfe-compliance/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/mfe-compliance/public"
          }
        ],
        "styles": [
          "apps/mfe-compliance/src/styles.css"
        ]
      },
      "configurations": {
        "production": {
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "development"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/angular:dev-server",
      "options": {
        "port": 4205,
        "publicHost": "http://localhost:4205"
      },
      "configurations": {
        "production": {
          "buildTarget": "mfeCompliance:build:production"
        },
        "development": {
          "buildTarget": "mfeCompliance:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "mfeCompliance:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "buildTarget": "mfeCompliance:test-build",
        "tsConfig": "apps/mfe-compliance/tsconfig.spec.json",
        "runner": "vitest",
        "include": ["**/*.spec.ts"],
        "watch": false
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "defaultConfiguration": "production",
      "options": {
        "buildTarget": "mfeCompliance:build",
        "port": 4205,
        "watch": false
      },
      "configurations": {
        "development": {
          "buildTarget": "mfeCompliance:build:development"
        },
        "production": {
          "buildTarget": "mfeCompliance:build:production"
        }
      }
    }
  }
}
